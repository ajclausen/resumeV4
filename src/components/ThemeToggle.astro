<theme-toggle>
  <button class="lux-theme-toggle" aria-label="Toggle theme">
    <!-- Sun icon (shown in dark mode) -->
    <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
    <!-- Moon icon (shown in light mode) -->
    <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
  </button>
</theme-toggle>

<style is:global>
  .dark .theme-icon-sun { display: block; }
  .dark .theme-icon-moon { display: none; }
  html:not(.dark) .theme-icon-sun { display: none; }
  html:not(.dark) .theme-icon-moon { display: block; }
</style>

<script>
  class ThemeToggle extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector('button')!;
      btn.addEventListener('click', () => {
        const root = document.documentElement;
        const isDark = root.classList.contains('dark');
        root.classList.toggle('dark');
        const newTheme = isDark ? 'light' : 'dark';
        localStorage.setItem('theme', newTheme);

        // Sync body bg + theme-color meta
        const bgColor = newTheme === 'dark' ? '#0c0c0c' : '#f8fafc';
        document.body.style.background = bgColor;
        const tc = document.querySelector('meta[name="theme-color"]');
        if (tc) tc.setAttribute('content', bgColor);
      });
    }
  }
  customElements.define('theme-toggle', ThemeToggle);
</script>
