---
import { EDUCATION, CERTIFICATIONS } from '../data';
---

<section class="lux-edu-section">
  <div class="lux-container">
    <div data-reveal>
      <div class="lux-section-header">
        <span class="lux-section-num">04</span>
        <h2 class="lux-section-title">Credentials</h2>
      </div>
    </div>
    <div class="lux-edu-grid">
      <!-- Education Column -->
      <div>
        <div data-reveal>
          <div class="lux-edu-column-label">Education</div>
        </div>
        {EDUCATION.map((edu, i) => (
          <div data-reveal data-reveal-delay={String(i * 80)}>
            <div class="lux-edu-item">
              <div class="lux-edu-period">{edu.period}</div>
              <div class="lux-edu-degree">{edu.degree}</div>
              <div class="lux-edu-institution">{edu.institution}</div>
              <p class="lux-edu-desc">{edu.description}</p>
              {edu.courses && (
                <div class="lux-edu-courses">
                  {edu.courses.map((course) => (
                    <span class="lux-edu-course">{course}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Certifications Column -->
      <div>
        <div data-reveal>
          <div class="lux-edu-column-label">Certifications</div>
        </div>
        <div data-reveal data-reveal-delay="100">
          <div class="lux-cert-list">
            {CERTIFICATIONS.map((cert) => (
              <div class="lux-cert-item">
                <!-- Check icon -->
                <svg class="lux-cert-check" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="lux-cert-name">{cert.name}</span>
                <span class="lux-cert-meta">
                  <span class="lux-cert-issuer-full">{cert.issuer}</span>
                  <span class="lux-cert-issuer-short">{cert.issuer === 'Linux Professional Institute' ? 'LPI' : cert.issuer}</span>
                  {' '}&middot; {cert.year}
                </span>
                {cert.url && (
                  <a
                    href={cert.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="lux-cert-link"
                    title="View credential"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
